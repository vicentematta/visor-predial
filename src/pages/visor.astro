cat > src/pages/visor.astro << 'EOF'
---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Visor Predial Futrono',
  description: 'Catastro SII + Capas CIREN para investigación de propiedades rurales',
};
---

<Layout metadata={metadata}>
  <div style="width:100%;height:calc(100vh - 70px);margin:0;padding:0;">
    <iframe
      src="/visor.html"
      style="width:100%;height:100%;border:none;"
      title="Visor Predial Futrono"
    ></iframe>
  </div>
</Layout>
EOF
